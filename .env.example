# 1. Make a copy of this file and name the copy ".env"  (just a dot + env, no name)
# 2. Get a FREE key at https://console.groq.com/keys
# 3. Paste it after the = sign below (no spaces, no quotes)
#
# The real ".env" file is ignored by git, so your key stays private.

GROQ_API_KEY=your_groq_api_key_here

# ---- Gmail: auto-email the plan to visitors + a lead copy to you ----
# 1. Turn on 2-Step Verification on your Google account.
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Fill these in (the app still runs without them — it just won't email).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
# Optional: where the "new lead" copy is sent (defaults to GMAIL_USER)
LEAD_NOTIFY_EMAIL=
